<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Formato de los mensajes -->
    <property name="PATRON" value="%d{yyyy-MM-dd HH:mm:ss} [%level] %logger{36} - %msg%n"/>

    <!-- Muestra logs en consola -->
    <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${PATRON}</pattern>
        </encoder>
    </appender>

    <!-- Guarda logs en archivo -->
    <appender name="ARCHIVO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/sistema-votacion.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Crea un archivo nuevo cada día -->
            <fileNamePattern>logs/sistema-votacion-%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Guarda los últimos 30 días -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${PATRON}</pattern>
        </encoder>
    </appender>

    <!-- Nivel de logs del proyecto -->
    <logger name="com.votacion.sistema_votacion" level="INFO"/>

    <!-- Configuración raíz -->
    <root level="INFO">
        <appender-ref ref="CONSOLA"/>
        <appender-ref ref="ARCHIVO"/>
    </root>

</configuration>